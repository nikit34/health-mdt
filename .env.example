# === REQUIRED (pick one) ===
# Option A — Claude Pro/Max subscription via setup token.
# No pay-per-use billing; agents route through the `claude` CLI inside the
# api container (installed in the Dockerfile). Uses `claude-agent-sdk` under
# the hood. Generate: `claude setup-token` on a machine where Claude Code is
# logged into your subscription, paste the output here.
CLAUDE_CODE_OAUTH_TOKEN=

# Option B — pay-per-use Anthropic API key.
# Faster (no subprocess startup), cheaper once you pass a few agent calls per
# day, and supports explicit prompt caching. Get one at console.anthropic.com.
# When BOTH are set, api_key wins (faster path, explicit cache control).
ANTHROPIC_API_KEY=

# === BASIC CONFIG ===
# Domain where this instance will be served (used by Caddy for HTTPS)
# For local dev, leave as localhost. For VPS, set to your domain e.g. health.example.com
DOMAIN=localhost

# === AUTH ===
# "pin" — single-user mode (default). Uses ACCESS_PIN below.
# "oauth" — multi-user mode via Google OAuth. Requires OAUTH_GOOGLE_CLIENT_ID/SECRET.
AUTH_MODE=pin

# 6-digit PIN (pin mode). Leave empty to auto-generate on first start (printed to deploy logs).
ACCESS_PIN=

# Single-user convenience: when true, /auth/mode returns the PIN so the login
# form pre-fills it. Anyone who can reach the endpoint will see the PIN —
# keep false on public deploys, true only on local/private instances.
AUTO_FILL_PIN=false

# Signs session cookies in oauth mode. Auto-generated to data/session_secret if empty.
SESSION_SECRET=

# Google OAuth (oauth mode) — create credentials at https://console.cloud.google.com
# Authorized redirect URI: https://<DOMAIN>/api/auth/oauth/google/callback
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# Comma-separated emails allowed to sign in. Empty = anyone with Google account.
# Example: founder@example.com,co-founder@example.com
OAUTH_ALLOWED_EMAILS=

# === OPTIONAL: DATA SOURCES ===
# Withings (scale, BP cuff, sleep mat, body composition).
# Create a Public Cloud app at https://developer.withings.com → get client_id + secret.
# Redirect URI to register in the app:
#   https://<DOMAIN>/api/sources/withings/callback
# (for localhost: http://localhost/api/sources/withings/callback)
# Per-user tokens are stored in the DB after the OAuth flow — no manual user tokens here.
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=

# Apple Health — no credentials needed. Users export from Health app on iPhone
# (Profile → Export All Health Data → export.zip) and upload in onboarding / settings.

# === OPTIONAL: EVIDENCE ===
# Semantic Scholar — optional; API works without key but has lower rate limits (100rpm).
# Request a key at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# === OPTIONAL: TELEGRAM BOT ===
# Create a bot via @BotFather and paste the token here.
# Without a token, the Telegram channel is disabled and everything works through the web UI.
TELEGRAM_BOT_TOKEN=

# === OPTIONAL: EMAIL NOTIFICATIONS (SMTP) ===
# Configure to receive daily briefs and MDT reports by email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS=true

# === OPTIONAL: WEB PUSH (VAPID) ===
# Auto-generated on first start. Only set manually if migrating.
# VAPID_PRIVATE_KEY=
# VAPID_PUBLIC_KEY=
# Contact email for push service errors:
VAPID_MAILTO=

# === OPTIONAL: MODEL TUNING ===
# Main model for agents. Defaults to Claude Sonnet 4.6.
AGENT_MODEL=claude-sonnet-4-6
# Heavier model used for weekly/monthly synthesis (optional).
SYNTHESIS_MODEL=claude-opus-4-6

# === INTERNAL ===
# Don't change unless you know what you're doing.
DATABASE_URL=sqlite:///data/health.db
LOG_LEVEL=INFO
TIMEZONE=Europe/Amsterdam
