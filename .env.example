# === REQUIRED ===
# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# === BASIC CONFIG ===
# Domain where this instance will be served (used by Caddy for HTTPS)
# For local dev, leave as localhost. For VPS, set to your domain e.g. health.example.com
DOMAIN=localhost

# Access PIN — 6-digit code required on first load and to pair the Telegram bot.
# Leave empty to auto-generate on first start (printed to deploy logs + stored in data/access.pin).
ACCESS_PIN=

# === OPTIONAL: DATA SOURCES ===
# Oura ring — get personal access token at https://cloud.ouraring.com/personal-access-tokens
OURA_PERSONAL_ACCESS_TOKEN=

# === OPTIONAL: TELEGRAM BOT ===
# Create a bot via @BotFather and paste the token here.
# Without a token, the Telegram channel is disabled and everything works through the web UI.
TELEGRAM_BOT_TOKEN=

# === OPTIONAL: MODEL TUNING ===
# Main model for agents. Defaults to Claude Sonnet 4.6.
AGENT_MODEL=claude-sonnet-4-6
# Heavier model used for weekly/monthly synthesis (optional).
SYNTHESIS_MODEL=claude-opus-4-6

# === INTERNAL ===
# Don't change unless you know what you're doing.
DATABASE_URL=sqlite:///data/health.db
LOG_LEVEL=INFO
TIMEZONE=Europe/Amsterdam
