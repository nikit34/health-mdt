{
	admin off
}

# Main site block.
# When DOMAIN=localhost, Caddy sees "http://localhost" → plain HTTP, no TLS.
# When DOMAIN=real.domain.com, Caddy auto-provisions HTTPS via Let's Encrypt.
{$CADDY_SITE_ADDRESS} {
	encode zstd gzip

	# API routes
	handle /api/* {
		uri strip_prefix /api
		reverse_proxy api:8000
	}

	# Server-sent events for agent streaming — disable buffering
	handle /api/chat/ask/stream* {
		uri strip_prefix /api
		reverse_proxy api:8000 {
			flush_interval -1
		}
	}

	# Everything else → Next.js web app
	handle {
		reverse_proxy web:3000
	}

	# Security headers (only meaningful for real domains with TLS)
	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	log {
		output stdout
		format console
	}
}
